APP_NAME="House of Parfum"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://houseofparfum.axelnova.tech

APP_TIMEZONE=Asia/Kuala_Lumpur
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
# Resolves to the shared axelnova-mysql container via the axelnova-shared network.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hop_db
DB_USERNAME=hop_user
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@houseofparfum.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://houseofparfum.axelnova.tech
# Single-origin deploy (frontend + /api on the same host), so CORS is
# largely moot — left set for any tooling that issues preflights.
CORS_ALLOWED_ORIGINS=https://houseofparfum.axelnova.tech
