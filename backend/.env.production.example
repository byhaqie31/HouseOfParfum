APP_NAME="House of Parfum"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hop-api.axelnova.tech

APP_TIMEZONE=Asia/Kuala_Lumpur

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
# Resolves to the shared axelnova-mysql container via the axelnova-shared network.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hop_db
DB_USERNAME=hop_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@houseofparfum.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://houseofparfum.axelnova.tech
