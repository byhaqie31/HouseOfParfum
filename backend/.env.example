APP_NAME="House of Parfum"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_TIMEZONE=Asia/Kuala_Lumpur
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Inside the docker stack, host is `mysql` (axelnova-infra service).
# Use 127.0.0.1 if running natively on the Mac.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hop_db
DB_USERNAME=hop_user
DB_PASSWORD=hop_local_pw

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@houseofparfum.local"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
